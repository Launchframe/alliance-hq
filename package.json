{
  "name": "alliance-hq",
  "version": "0.16.2",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "next dev -p 5175",
    "build": "npm run db:prepare && next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:validate": "node scripts/i18n/validate.mjs",
    "i18n:translate": "node scripts/i18n/translate.mjs",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:seed-rbac": "node scripts/rbac/seed.mjs",
    "seed:test-matrix": "tsx scripts/dev/seed-test-matrix.ts",
    "db:prepare": "npm run db:migrate && npm run db:seed",
    "db:validate-journal": "node scripts/db/validate-migration-journal.mjs",
    "db:studio": "drizzle-kit studio",
    "har:catalog": "node scripts/har/extract-catalog.mjs",
    "discord:register-commands": "node scripts/discord/register-commands.mjs",
    "discord:dev:keygen": "node scripts/discord/dev-interaction.mjs keygen",
    "discord:dev:ping": "node scripts/discord/dev-interaction.mjs ping",
    "discord:dev:slash": "node scripts/discord/dev-interaction.mjs slash",
    "discord:dev:button": "node scripts/discord/dev-interaction.mjs button",
    "discord:dev:seed-auth": "node scripts/discord/dev-seed-auth.mjs",
    "release:compile-note": "tsx scripts/release-notes/compile-note.ts",
    "release:backfill-main": "tsx scripts/release-notes/backfill-main-releases.ts",
    "release:ship": "tsx scripts/release-notes/ship.ts",
    "release-notes:publish": "tsx scripts/release-notes/publish-notes.ts",
    "release:notify-discord": "tsx scripts/release-notes/notify-discord.ts",
    "video:worker": "node scripts/workers/video-processor.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:video-ocr-mock": "VIDEO_OCR_PROVIDER=mock VIDEO_OCR_ALLOW_NONPROD=true playwright test e2e/video-ocr-nonprod-provider.spec.ts",
    "test:e2e:video-ocr-local": "VIDEO_OCR_PROVIDER=local VIDEO_OCR_ALLOW_NONPROD=true playwright test e2e/video-ocr-nonprod-provider.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "vercel:analyze-function-trace": "node scripts/vercel/analyze-function-trace.mjs",
    "build:analyze-function-trace": "npm run build && npm run vercel:analyze-function-trace",
    "postinstall": "node scripts/patch-tesseract-node-getcore.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@base44/sdk": "^0.8.32",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/functions": "^3.4.3",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "ffmpeg-static": "^5.3.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "marked": "^15.0.12",
    "mermaid": "^11.16.0",
    "modern-screenshot": "^4.7.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.13.0",
    "postgres": "^3.4.9",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.15.4",
    "resend": "^6.14.0",
    "semver": "^7.8.4",
    "sharp": "^0.35.1",
    "tesseract.js": "^7.0.0",
    "tweetnacl": "^1.0.3",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.0",
    "@img/sharp-linux-x64": "0.35.1"
  },
  "allowScripts": {
    "tesseract.js@7.0.0": true,
    "sharp@0.34.5": true,
    "sharp@0.35.1": true,
    "unrs-resolver@1.12.2": true
  }
}
