# Local Postgres (used when NODE_ENV is not production)
# Do NOT add ?schema=public — that is Prisma-only and breaks postgres.js
# e.g. postgresql://postgres:yourpassword@localhost:5432/alliance_hq_dev
LOCAL_DATABASE_URL=

# Playwright E2E — dedicated database (recommended: alliance_hq_e2e)
# createdb alliance_hq_e2e
# E2E_DATABASE_URL=postgresql://localhost/alliance_hq_e2e npm run test:e2e
E2E_DATABASE_URL="postgresql://localhost/alliance_hq_e2e"

# Remote Postgres (Neon / production) — used in production, or locally if LOCAL_DATABASE_URL is unset
DATABASE_URL=

# 32-byte key — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# HQ auth (magic link via Resend; password + passkey also supported)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
RESEND_API_KEY=
# WebAuthn relies on NEXT_PUBLIC_APP_URL host (e.g. frontline.gay / localhost).
# Production (after Resend verifies frontline.gay):
EMAIL_FROM=Alliance HQ <auth@frontline.gay>
# Local dev without verified domain:
# EMAIL_FROM=Alliance HQ <onboarding@resend.dev>
# Resend sandbox: onboarding@resend.dev only delivers to your Resend account email.
# Magic links are printed to the dev server console (NODE_ENV !== production).
# Optional: skip Resend entirely and log only — AUTH_MAGIC_LINK_LOG_ONLY=1
# Email verification codes (6-digit) use the same Resend sender; dev console logs the code too.
# Optional: AUTH_EMAIL_CODE_LOG_ONLY=1
# Send-code abuse limits (POST /api/auth/send-code): global + per-IP caps; PM email when global cap blocks.
# AUTH_SEND_CODE_GLOBAL_MAX_PER_MIN=50
# AUTH_SEND_CODE_IP_MAX_PER_HOUR=10
# E2E only (never in production): E2E_TEST=1 and E2E_EMAIL_CODE=424242 for *@alliance-hq.test addresses

# Optional: Google / Discord SSO (web sign-in — separate from Discord bot token below)
# Google Cloud Console → OAuth client (Web) → redirect: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Discord Developer Portal → OAuth2 → redirect: {NEXT_PUBLIC_APP_URL}/api/auth/callback/discord
# AUTH_DISCORD_ID=              # same as DISCORD_APPLICATION_ID
# AUTH_DISCORD_SECRET=          # OAuth2 client secret (not the bot token)

# Google Search Console site verification (content value only — not the full meta tag)
# GOOGLE_SITE_VERIFICATION=

# Public URL for metadata, magic links, invite URLs
NEXT_PUBLIC_APP_URL=https://frontline.gay
# Local dev: http://localhost:5175

# Optional: Google Cloud Translation API key for npm run i18n:translate
# GOOGLE_TRANSLATE_API_KEY=

# Community feedback
# BUG_REPORT_CAPTURE_SECRET=  # optional; falls back to TOKEN_ENCRYPTION_KEY
# NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite

# Optional: Base44 defaults (ashed.online)
BASE44_APP_ID=692b7e16a524fdd9dff3332d
BASE44_ORIGIN_URL=https://ashed.online

# Last War UID → in-game name lookup (/link, avatars). Override only if the platform URL changes.
# LASTWAR_PLAYER_LOOKUP_URL=https://lastwar-platform.lastwargame.com/redemptionCode.php?method=login

# Video pipeline — local dev uses /.data/uploads when R2 is not fully configured
VIDEO_WORKER_SECRET=dev-secret
# Max upload size for R2 direct flow (bytes). Default 512 MiB (536870912).
# VIDEO_MAX_UPLOAD_BYTES=536870912
# Vercel Cron backup — set in production; Vercel sends Authorization: Bearer $CRON_SECRET
# CRON_SECRET=
# First platform maintainer: set to your Ashed email; auto-promoted on connect when no maintainer exists yet
# PLATFORM_BOOTSTRAP_EMAIL=you@example.com
# Production: require admin invite before Ashed connection-key connect (native users always need invite).
# HQ_ASHED_INVITE_REQUIRED=true|false  (legacy alias: HQ_INVITE_REQUIRED)
# Defaults to on when VERCEL_ENV=production. Native alliance access is always invite-only.
# HQ_ASHED_INVITE_REQUIRED=true
# Local worker defaults to http://localhost:5175 when LOCAL_DATABASE_URL is localhost.
# Override only if your dev server runs elsewhere:
# VIDEO_WORKER_BASE_URL=http://localhost:5175
# Production: set to your deployed URL so the worker can POST /api/internal/video-process
# VIDEO_WORKER_BASE_URL=https://frontline.gay
# Parallel Ashed UploadFile + ExtractData calls per video job (default 4, max 8)
# VIDEO_ASHED_FRAME_CONCURRENCY=4
# VIDEO_PIPELINE_ANALYTICS=0  # disable Vercel custom events (local logs still emit)
# Cloudflare R2 (required on Vercel for video storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Browser direct uploads require CORS on the bucket (PUT from your app origin). Example:
# AllowedMethods: PUT, GET, HEAD | AllowedOrigins: https://your-app.example | AllowedHeaders: *

# Discord VR bot (slash commands /link, /vr, /immunity, /link-to-ashed-seat, /link-alliance, /set-vr-report-channel, /vr-report, /takedown-teams)
# DISCORD_APPLICATION_ID=
# DISCORD_PUBLIC_KEY=           # Developer Portal → General → Public Key (64 hex chars)
# DISCORD_BOT_PUBLIC_KEY=       # legacy alias for DISCORD_PUBLIC_KEY
# DISCORD_BOT_TOKEN=           # register-commands script + daily report posts
# DISCORD_GUILD_ID=            # optional; guild-scoped command registration + daily report guild lookup
# DISCORD_ALLIANCE_ID=         # LEGACY single-tenant only — must pair with DISCORD_GUILD_ID; unset for multi-tenant hosted deploys
# DISCORD_ALLIANCE_SEASON_KEY= # fallback season when alliances.currentSeasonKey unset
# DISCORD_VR_REPORT_CHANNEL_ID= # LEGACY single-tenant nightly channel — prefer /set-vr-report-channel per guild
# DISCORD_RELEASE_NOTES_CHANNEL_ID= # production release announcements
# VR_BOT_ASHED_BEARER_TOKEN=   # legacy shared Ashed token (use only with tag guard below)
# VR_BOT_ASHED_ALLIANCE_TAG=   # required with legacy token — only this alliance tag may use the shared JWT
# VR_DAILY_REPORT_SECRET=      # optional Bearer for manual daily report trigger
# DISCORD_BOT_API_SECRET=      # optional Bearer for POST /api/internal/discord/vr
#
# Multi-tenant bot access control:
# ELIGIBLE_BOT_ALLIANCE_LINK_TAGS=LFgo,TAG2  # comma-separated; unset = allow all tags
#
# Secure credential setup (/link-to-ashed-seat → /discord/authorize HQ page):
# Connection keys are entered on the HQ web form (HTTPS) — never in Discord.
# The NEXT_PUBLIC_APP_URL above is used to build the authorize URL.
#
# Local Discord auth development (synthetic signed interactions):
# npm run discord:dev:keygen prints a local-only public/private keypair.
# If ELIGIBLE_BOT_ALLIANCE_LINK_TAGS is set above, include DEV (the seed tag) or
# unset it, otherwise /link-alliance and /link-to-ashed-seat reject tag DEV.
# DISCORD_DEV_PRIVATE_KEY=      # paired with DISCORD_PUBLIC_KEY for local helper signing
# DISCORD_DEV_GUILD_ID=dev-guild-1
# DISCORD_DEV_CHANNEL_ID=dev-channel-1
# DISCORD_DEV_USER_ID=dev-user-1
# DISCORD_DEV_USERNAME=DevUser
# DISCORD_DEV_SEED_ALLOW_REMOTE=1 # only for disposable non-local dev databases

# Release notes (Edge Config publish + runtime read)
# EDGE_CONFIG=                 # Vercel Edge Config connection string (production runtime)
# EDGE_CONFIG_ID=              # For npm run release-notes:publish
# VERCEL_API_TOKEN=            # For Edge Config PATCH during ship/publish
